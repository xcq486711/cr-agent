diff --git a/src/test/java/com/elderlycare/backend/service/AlertEventServiceTest.java b/src/test/java/com/elderlycare/backend/service/AlertEventServiceTest.java
new file mode 100644
index 0000000..389087b
--- /dev/null
+++ b/src/test/java/com/elderlycare/backend/service/AlertEventServiceTest.java
@@ -0,0 +1,185 @@
+package com.elderlycare.backend.service;
+
+import com.baomidou.mybatisplus.core.conditions.query.LambdaQueryWrapper;
+import com.baomidou.mybatisplus.core.metadata.IPage;
+import com.elderlycare.backend.BaseServiceTest;
+import com.elderlycare.backend.dto.request.AlertEventHandleRequest;
+import com.elderlycare.backend.dto.vo.AlertEventVO;
+import com.elderlycare.backend.dto.vo.AlertStatisticsVO;
+import com.elderlycare.backend.entity.AlertEvent;
+import com.elderlycare.backend.entity.AlertRule;
+import com.elderlycare.backend.entity.Resident;
+import com.elderlycare.backend.exception.BusinessException;
+import com.elderlycare.backend.mapper.AlertEventMapper;
+import com.elderlycare.backend.mapper.AlertRuleMapper;
+import org.junit.jupiter.api.BeforeEach;
+import org.junit.jupiter.api.DisplayName;
+import org.junit.jupiter.api.Test;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.transaction.annotation.Transactional;
+
+import java.math.BigDecimal;
+import java.time.LocalDateTime;
+
+import static org.junit.jupiter.api.Assertions.*;
+
+@Transactional
+class AlertEventServiceTest extends BaseServiceTest {
+
+    @Autowired
+    private AlertEventService alertEventService;
+
+    @Autowired
+    private AlertEventMapper alertEventMapper;
+
+    @Autowired
+    private AlertRuleMapper alertRuleMapper;
+
+    private Resident resident;
+    private AlertRule rule;
+
+    @BeforeEach
+    void setUp() {
+        resident = createTestResident("测试老人");
+
+        // 确保有一条启用的规则
+        rule = alertRuleMapper.selectOne(
+                new LambdaQueryWrapper<AlertRule>()
+                        .eq(AlertRule::getEnabled, 1));
+        if (rule == null) {
+            rule = new AlertRule();
+            rule.setRuleKey("test_rule");
+            rule.setRuleName("测试规则");
+            rule.setCategory("vital");
+            rule.setEnabled(1);
+            rule.setParam1Label("上限");
+            rule.setParam1Value(new BigDecimal("100"));
+            rule.setParam1Unit("bpm");
+            rule.setSortOrder(99);
+            alertRuleMapper.insert(rule);
+        }
+    }
+
+    private AlertEvent createTestEvent(String status) {
+        AlertEvent event = new AlertEvent();
+        event.setResidentId(resident.getId());
+        event.setResidentName(resident.getName());
+        event.setRoomNo("101");
+        event.setRuleKey(rule.getRuleKey());
+        event.setCategory(rule.getCategory());
+        event.setSeverity("重要");
+        event.setTitle("测试告警");
+        event.setDescription("测试描述");
+        event.setMeasuredValue("120");
+        event.setMeasuredUnit("bpm");
+        event.setThresholdValue("上限 100bpm");
+        event.setStatus(status);
+        event.setTriggerTime(LocalDateTime.now());
+        alertEventMapper.insert(event);
+        return event;
+    }
+
+    @Test
+    @DisplayName("分页查询告警列表")
+    void shouldPageEvents() {
+        createTestEvent("待处理");
+        createTestEvent("待处理");
+
+        IPage<AlertEventVO> page = alertEventService.pageEvents("待处理", null, null, null, null, null, 1, 10);
+        assertTrue(page.getTotal() >= 2);
+    }
+
+    @Test
+    @DisplayName("查询告警详情含历史同类告警")
+    void shouldGetEventDetailWithHistory() {
+        AlertEvent e1 = createTestEvent("已归档");
+        AlertEvent e2 = createTestEvent("待处理");
+
+        AlertEventVO detail = alertEventService.getEventDetail(e2.getId());
+        assertNotNull(detail);
+        assertEquals(e2.getTitle(), detail.getTitle());
+        assertNotNull(detail.getHistoryAlerts());
+        assertTrue(detail.getHistoryAlerts().stream().anyMatch(h -> h.getId().equals(e1.getId())));
+    }
+
+    @Test
+    @DisplayName("告警统计与数据一致")
+    void shouldGetStatistics() {
+        createTestEvent("待处理");
+        createTestEvent("待处理");
+        createTestEvent("已归档");
+
+        AlertStatisticsVO stats = alertEventService.getStatistics();
+        assertTrue(stats.getImportantCount() >= 2);
+    }
+
+    @Test
+    @DisplayName("处理告警：待处理→处理中→已归档")
+    void shouldHandleEventFromPendingToArchived() {
+        AlertEvent event = createTestEvent("待处理");
+
+        // 第一次：接单 → 处理中
+        AlertEventHandleRequest req1 = new AlertEventHandleRequest();
+        req1.setHandlerName("张医生");
+        req1.setHandleNotes("已查看");
+        req1.setHandleResult(null);
+        AlertEventVO vo1 = alertEventService.handleEvent(event.getId(), req1);
+        assertEquals("处理中", vo1.getStatus());
+
+        // 第二次：提交结果 → 已归档
+        AlertEventHandleRequest req2 = new AlertEventHandleRequest();
+        req2.setHandlerName("张医生");
+        req2.setHandleNotes("已给药处理");
+        req2.setHandleResult("已解决");
+        AlertEventVO vo2 = alertEventService.handleEvent(event.getId(), req2);
+        assertEquals("已归档", vo2.getStatus());
+        assertEquals("已解决", vo2.getHandleResult());
+    }
+
+    @Test
+    @DisplayName("归档告警：待处理→已归档")
+    void shouldArchiveEvent() {
+        AlertEvent event = createTestEvent("待处理");
+
+        AlertEventVO vo = alertEventService.archiveEvent(event.getId());
+        assertEquals("已归档", vo.getStatus());
+    }
+
+    @Test
+    @DisplayName("已归档告警不可重复处理")
+    void shouldRejectHandleArchivedEvent() {
+        AlertEvent event = createTestEvent("已归档");
+
+        AlertEventHandleRequest req = new AlertEventHandleRequest();
+        req.setHandleNotes("尝试处理");
+        req.setHandleResult("已解决");
+
+        assertThrows(BusinessException.class,
+                () -> alertEventService.handleEvent(event.getId(), req));
+    }
+
+    @Test
+    @DisplayName("已归档告警不可重复归档")
+    void shouldRejectArchiveArchivedEvent() {
+        AlertEvent event = createTestEvent("已归档");
+
+        assertThrows(BusinessException.class,
+                () -> alertEventService.archiveEvent(event.getId()));
+    }
+
+    @Test
+    @DisplayName("模拟生成告警：生成数据关联真实老人和规则")
+    void shouldGenerateMockEvents() {
+        int count = alertEventService.generateMockEvents();
+        assertTrue(count > 0, "应至少生成 1 条告警");
+
+        AlertEvent latest = alertEventMapper.selectList(null)
+                .stream()
+                .reduce((a, b) -> b)
+                .orElse(null);
+        assertNotNull(latest);
+        assertNotNull(latest.getResidentId());
+        assertNotNull(latest.getRuleKey());
+        assertEquals("待处理", latest.getStatus());
+    }
+}

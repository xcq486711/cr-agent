# CR-Agent 环境变量配置

# DeepSeek API
DEEPSEEK_API_KEY=sk-eabcb3f0ec4a452e9e47a962fe9ca0e6
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 模型配置
CR_AGENT_MODEL=deepseek-v4-pro
CR_AGENT_TEMPERATURE=0.1
CR_AGENT_MAX_RETRIES=10
CR_AGENT_TIMEOUT=60

# 审查配置
CR_AGENT_CONFIDENCE_THRESHOLD=0.7
CR_AGENT_MAX_CONCURRENT_AGENTS=10

# 数据库
DATABASE_URL=postgresql+asyncpg://cr_agent:cr_agent@localhost:5432/cr_agent

# Redis
REDIS_URL=redis://localhost:6379

# GitHub App (可选, 用于 webhook 自动审查)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
